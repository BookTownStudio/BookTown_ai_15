rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
       ========================= */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isActiveSignedIn() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuspended != true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != "suspended";
    }

    function isActiveOwner(uid) {
      return isActiveSignedIn() && request.auth.uid == uid;
    }

    function isAdminUser() {
      return isSignedIn()
        && request.auth.token.role in ['superadmin', 'moderator', 'system'];
    }

    function isSuperAdminUser() {
      return isSignedIn()
        && (
          request.auth.token.superadmin == true
          || request.auth.token.role == 'superadmin'
        );
    }

    function isSystemShelfId(shelfId) {
      return shelfId == 'currently-reading'
          || shelfId == 'want-to-read'
          || shelfId == 'finished';
    }

    function isShelfOwner() {
      return isSignedIn()
        && request.auth.uid == resource.data.ownerId;
    }

    function isCreateShelfOwner() {
      return isSignedIn()
        && request.auth.uid == request.resource.data.ownerId;
    }

    function isShelfMetadataPatch() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "titleEn",
        "titleAr",
        "descriptionEn",
        "descriptionAr",
        "visibility",
        "userCoverUrl",
        "updatedAt"
      ]);
    }

    function resolveShelfVisibility(shelfData) {
      return shelfData.visibility is string
        ? shelfData.visibility
        : "public";
    }

    function canReadShelfByData(shelfData) {
      let ownerId = shelfData.ownerId is string ? shelfData.ownerId : "";
      let visibility = resolveShelfVisibility(shelfData);

      return (
        visibility == "public"
        || visibility == "unlisted"
        || (isSignedIn() && request.auth.uid == ownerId)
      );
    }

    function isBoundedString(value, maxLen) {
      return value is string
        && value.size() > 0
        && value.size() <= maxLen;
    }

    function isAllowedUserProfilePatch() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "name",
          "bioEn",
          "bioAr",
          "avatarUrl",
          "bannerUrl",
          "lastActive",
          "updatedAt",
          "aiConsent"
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.handle == resource.data.handle
        && request.resource.data.status == resource.data.status
        && request.resource.data.isSuspended == resource.data.isSuspended;
    }

    function isFollowerOf(authorId) {
      return isSignedIn()
        && authorId is string
        && authorId.size() > 0
        && exists(/databases/$(database)/documents/users/$(authorId)/followers/$(request.auth.uid));
    }

    function resolvePostVisibility(postData) {
      return postData.visibility is string
        ? postData.visibility
        : (
            postData.visibility is map
            && postData.visibility.scope is string
              ? postData.visibility.scope
              : "private"
          );
    }

    function isReadablePostState(postData) {
      return postData.isDeleted != true
        && (
          !("status" in postData)
          || (
            postData.status is string
            && postData.status == "published"
          )
        );
    }

    function canReadPostByData(postData) {
      let visibility = resolvePostVisibility(postData);
      let authorId = postData.authorId is string ? postData.authorId : "";

      return isReadablePostState(postData)
        && (
          visibility == "public"
          || (
            visibility == "followers"
            && isSignedIn()
            && (
              request.auth.uid == authorId
              || isFollowerOf(authorId)
            )
          )
          || (
            visibility == "private"
            && isSignedIn()
            && request.auth.uid == authorId
          )
        );
    }

    function canReadPostById(postId) {
      return exists(/databases/$(database)/documents/posts/$(postId))
        && canReadPostByData(
          get(/databases/$(database)/documents/posts/$(postId)).data
        );
    }

    function isPublicPostById(postId) {
  return postId is string
    && postId.size() > 0
    && exists(/databases/$(database)/documents/posts/$(postId))
    && resolvePostVisibility(
         get(/databases/$(database)/documents/posts/$(postId)).data
       ) == "public"
    && get(/databases/$(database)/documents/posts/$(postId)).data.isDeleted != true
    && (
         !("status" in get(/databases/$(database)/documents/posts/$(postId)).data)
         || get(/databases/$(database)/documents/posts/$(postId)).data.status == "published"
       );
}

    function canReadAttachmentByData(attachmentData) {
      let uploaderUid =
        attachmentData.uploader is map
        && attachmentData.uploader.uid is string
          ? attachmentData.uploader.uid
          : "";

      let parentType = attachmentData.parentType is string
        ? attachmentData.parentType
        : "";
      let parentId = attachmentData.parentId is string
        ? attachmentData.parentId
        : "";

      return (
        isSignedIn()
        && uploaderUid.size() > 0
        && request.auth.uid == uploaderUid
      )
      || (
        parentType == "posts"
        && isPublicPostById(parentId)
      );
    }

    /* =========================
       USERS
       ========================= */
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create: if false;
      allow update: if isActiveOwner(uid) && isAllowedUserProfilePatch();
      allow delete: if false;

      match /follows_authors/{authorId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.authorId == authorId;
        allow delete: if isActiveOwner(uid);
      }

      match /likes/{postId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.postId == postId;
        allow delete: if isActiveOwner(uid);
      }

      match /reposts/{postId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid);
        allow delete: if isActiveOwner(uid);
      }

      match /post_bookmarks/{postId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.type == "post"
          && request.resource.data.entityId == postId;
        allow delete: if isActiveOwner(uid);
      }

      match /venue_bookmarks/{venueId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.type == "venue"
          && request.resource.data.entityId == venueId;
        allow delete: if isActiveOwner(uid);
      }

      match /event_bookmarks/{eventId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.type == "event"
          && request.resource.data.entityId == eventId;
        allow delete: if isActiveOwner(uid);
      }

      match /bookmarks/{bookmarkId} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.type == "quote";
        allow delete: if isActiveOwner(uid);
      }

      match /comment_likes/{commentLikeId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isActiveOwner(uid);
      }

      match /followers/{followerId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /following/{targetUid} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /projects/{projectId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /published_books/{bookId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /project_duplicate_ops/{opId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /project_publish_ops/{opId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /project_share_links/{projectId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /userBooks/{bookId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      match /shelves/{shelfId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;

        match /books/{bookId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if false;
        }
      }

      match /agent_sessions/{sessionId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isActiveOwner(uid);

        match /messages/{messageId} {
          allow read: if isOwner(uid);
          allow create, update, delete: if isActiveOwner(uid);
        }
      }

      match /reports/{reportId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isActiveOwner(uid);
      }

      match /blocks/{blockedUid} {
        allow read: if isOwner(uid);
        allow create, update: if isActiveOwner(uid)
          && request.resource.data.blockedUid == blockedUid;
        allow delete: if isActiveOwner(uid);
      }

      match /drafts/{draftId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isActiveOwner(uid);
      }

      match /meta/{metaId} {
        allow read: if isOwner(uid);
        allow create, update, delete: if isActiveOwner(uid);
      }
    }

    /* =========================
       PUBLIC PROFILES
       ========================= */
    match /public_profiles/{uid} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /* =========================
       AUTHORS (PUBLIC READ, SERVER WRITE)
       ========================= */
    match /authors/{authorId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /* =========================
       USER STATS
       ========================= */
    match /user_stats/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    /* =========================
       USER INTELLIGENCE PROFILES (SERVER AUTHORITY ONLY)
       ========================= */
    match /user_intelligence_profiles/{uid} {
      allow read, create, update, delete: if false;

      match /{subcollection}/{documentId} {
        allow read, create, update, delete: if false;
      }
    }

    /* =========================
       INTELLIGENCE SIGNAL QUEUE (SERVER AUTHORITY ONLY)
       ========================= */
    match /intelligence_signal_queue/{signalId} {
      allow read, create, update, delete: if false;
    }

    /* =========================
       INTELLIGENCE AGGREGATES (SUPERADMIN READ-ONLY)
       ========================= */
    match /intelligence_aggregates_global/{docId} {
      allow read: if isSuperAdminUser();
      allow create, update, delete: if false;
    }

    match /intelligence_aggregation_checkpoint/{docId} {
      allow read: if isSuperAdminUser();
      allow create, update, delete: if false;
    }

    /* =========================
       SYSTEM METRICS (SERVER-ONLY PROJECTIONS)
       ========================= */
    match /system_metrics/{metricId} {
      allow read, create, update, delete: if false;

      match /{document=**} {
        allow read, create, update, delete: if false;
      }
    }

    match /system_metrics_daily/{dateKey} {
      allow read, create, update, delete: if false;

      match /{document=**} {
        allow read, create, update, delete: if false;
      }
    }

    /* =========================
       AUDIT LOG (IMMUTABLE, SERVER WRITES ONLY)
       ========================= */
    match /audit_log/{logId} {
      allow read: if isSuperAdminUser();
      allow create, update, delete: if false;
    }

    /* =========================
       DELETION REQUESTS (SERVER AUTHORITY)
       ========================= */
    match /deletion_requests/{id} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    /* =========================
       NOTIFICATION PREFERENCES
       ========================= */
    match /notification_preferences/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isActiveOwner(uid);
      allow delete: if false;
    }

    /* =========================
       USER SETTINGS
       ========================= */
    match /user_settings/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isActiveOwner(uid);
      allow delete: if false;
    }

    /* =========================
       SHELVES (CANONICAL)
       ========================= */
    match /shelves/{shelfDocId} {

      allow read: if canReadShelfByData(resource.data);

      allow create, update, delete: if false;
    }

    /* =========================
       BOOKS (CATALOG)
       ========================= */
    match /books/{bookId} {
      allow get, list: if true;
      allow create, update, delete: if false;

      /* =========================
         📚 REVIEWS (SECURE)
         ========================= */
      match /reviews/{reviewId} {
        // Read only if review is public (or legacy without visibility) or owner.
        allow get, list: if
          (
            !("visibility" in resource.data)
            || resource.data.visibility == "public"
          )
          || (
            isSignedIn()
            && resource.data.userId == request.auth.uid
          );

        // Canonical writes are backend-only via validated callables.
        allow create, update, delete: if false;
      }
    }

    /* =========================
       USER REVIEWS PROJECTION (SERVER AUTHORITY)
       ========================= */
    match /user_reviews/{docId} {
      allow get, list: if false;
      allow create, update, delete: if false;
    }

    /* =========================
       EDITIONS
       ========================= */
    match /editions/{editionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /* =========================
       ATTACHMENTS
       ========================= */
    match /attachments/{attachmentId} {
      allow get: if canReadAttachmentByData(resource.data);
      allow list: if false;
      allow create, update: if false;
      allow delete: if false;
    }

    /* =========================
       📖 READING PROGRESS (SSoT)
       ========================= */
    match /reading_progress/{progressId} {

      allow get, list: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create, update: if false;

      allow delete: if false;
    }

    /* =========================
       LIBRARIAN SUGGESTION SESSIONS
       ========================= */
    match /librarian_suggestions/{sessionId} {
      allow get, list: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    /* =========================
       VENUES
       ========================= */
    match /venues/{venueId} {
      allow get, list: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && isBoundedString(request.resource.data.name, 120)
        && isBoundedString(request.resource.data.type, 80)
        && isBoundedString(request.resource.data.address, 240)
        && isBoundedString(request.resource.data.imageUrl, 1024)
        && request.resource.data.descriptionEn is string
        && request.resource.data.descriptionEn.size() <= 2000
        && request.resource.data.descriptionAr is string
        && request.resource.data.descriptionAr.size() <= 2000;

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && isBoundedString(request.resource.data.name, 120)
        && isBoundedString(request.resource.data.type, 80)
        && isBoundedString(request.resource.data.address, 240)
        && isBoundedString(request.resource.data.imageUrl, 1024)
        && request.resource.data.descriptionEn is string
        && request.resource.data.descriptionEn.size() <= 2000
        && request.resource.data.descriptionAr is string
        && request.resource.data.descriptionAr.size() <= 2000;

      allow delete: if false;

      match /reviews/{reviewId} {
        allow get, list: if true;

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.venueId == venueId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 1000;

        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.venueId == resource.data.venueId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 1000;

        allow delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }

    /* =========================
       EVENTS
       ========================= */
    match /events/{eventId} {
      allow get, list: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && isBoundedString(request.resource.data.titleEn, 120)
        && isBoundedString(request.resource.data.titleAr, 120)
        && isBoundedString(request.resource.data.type, 80)
        && isBoundedString(request.resource.data.dateTime, 64)
        && isBoundedString(request.resource.data.imageUrl, 1024)
        && request.resource.data.privacy in ['public', 'private']
        && request.resource.data.isOnline is bool
        && (
          (request.resource.data.isOnline == true
            && isBoundedString(request.resource.data.link, 1024))
          ||
          (request.resource.data.isOnline == false
            && isBoundedString(request.resource.data.venueName, 120))
        );

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && isBoundedString(request.resource.data.titleEn, 120)
        && isBoundedString(request.resource.data.titleAr, 120)
        && isBoundedString(request.resource.data.type, 80)
        && isBoundedString(request.resource.data.dateTime, 64)
        && isBoundedString(request.resource.data.imageUrl, 1024)
        && request.resource.data.privacy in ['public', 'private']
        && request.resource.data.isOnline is bool
        && (
          (request.resource.data.isOnline == true
            && isBoundedString(request.resource.data.link, 1024))
          ||
          (request.resource.data.isOnline == false
            && isBoundedString(request.resource.data.venueName, 120))
        );

      allow delete: if false;

      match /reviews/{reviewId} {
        allow get, list: if true;

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.venueId == eventId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 1000;

        allow update: if isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.venueId == resource.data.venueId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 1000;

        allow delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }

      match /rsvps/{uid} {
        allow get, list: if true;

        allow create, update: if isOwner(uid)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.eventId == eventId;

        allow delete: if isOwner(uid);
      }
    }

    match /venue_stats/{venueId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /event_stats/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /* =========================
       NOTIFICATIONS
       ========================= */
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid;
      allow create, delete: if false;
    }

    match /search_notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /post_stats/{postId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /post_analytics/{postId} {
      allow get, list: if isSuperAdminUser();
      allow create, update, delete: if false;

      match /viewers/{viewerUid} {
        allow read, create, update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow get: if isSignedIn()
        && (
          isAdminUser()
          || resource.data.reportedByUid == request.auth.uid
        );
      allow list: if isAdminUser();
      allow create, update, delete: if false;
    }

    match /moderation_log/{logId} {
      allow get, list: if isAdminUser();
      allow create, update, delete: if false;
    }

    match /activity_log/{activityId} {
      allow get, list: if isAdminUser();
      allow create, update, delete: if false;
    }

    /* =========================
       DIRECT MESSAGING (SERVER WRITE, PARTICIPANT READ)
       ========================= */
    match /conversations/{conversationId} {
      allow get, list: if isSignedIn()
        && resource.data.participantSet[request.auth.uid] == true;

      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow get, list: if isSignedIn()
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantSet[request.auth.uid] == true;
        allow create, update, delete: if false;
      }

      match /idempotency/{idempotencyId} {
        allow read, write: if false;
      }
    }

    /* =========================
       SOCIAL
       ========================= */
    match /posts/{postId} {
      allow read: if false;
      allow create, update, delete: if false;

      match /comments/{commentId} {
        allow read: if false;
        allow create, update, delete: if false;
      }
    }

    match /comments/{commentId} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    /* =========================
       WRITE PROJECTS
       ========================= */
    match /projects/{projectId} {
      allow read, create, update, delete: if false;
    }

    /* =========================
       IMPORT SESSIONS (SERVER WRITE, OWNER READ)
       ========================= */
    match /imports/{uid}/{document=**} {
      allow get, list: if isOwner(uid);
      allow create, update, delete: if false;
    }

    /* =========================
       DENY ALL (DEFAULT)
       ========================= */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
