rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /* =========================
       HELPERS
       ========================= */
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function isEpub() {
      return request.resource.contentType == 'application/epub+zip';
    }

    function isAllowedUserUploadMimeType() {
      return isPdf() || isEpub();
    }

    function isReasonableEbookSize() {
      // 50MB — aligned with ATTACHMENT_UPLOAD_CONTRACT_V1
      return request.resource.size < 50 * 1024 * 1024;
    }

    /* =========================
       📕 BOOK COVERS (CANONICAL — SERVER OWNED)
       ========================= */
    /*
      COVER_STORAGE_CONTRACT_V1
      - Publicly readable cover assets
      - Written ONLY by backend (Admin SDK bypasses rules)
      - No client writes
    */
    match /books/{bookId}/covers/{allPaths=**} {
  // Covers are publicly readable
  allow read: if true;

  // ❌ No client writes — server (Admin SDK) only
  allow write: if false;
}

    /* =========================
       📘 USER UPLOAD SOURCE FILES
       ========================= */
    /*
      USER_UPLOAD_SOURCE_CONTRACT_V1
      - Client can upload ONLY its own user_upload source file
      - Path is strictly books/{bookId}/original/{fileName}
      - Ownership and metadata are verified against Firestore book doc
    */
    match /books/{bookId}/original/{fileName} {
      allow read: if false;

      allow create, update: if isAuthenticated()
        && request.resource.size > 0
        && request.resource.size <= 25 * 1024 * 1024
        && isAllowedUserUploadMimeType()
        && firestore.exists(/databases/(default)/documents/books/$(bookId))
        && firestore.get(/databases/(default)/documents/books/$(bookId)).data.source == "user_upload"
        && firestore.get(/databases/(default)/documents/books/$(bookId)).data.ownerUid == request.auth.uid
        && firestore.get(/databases/(default)/documents/books/$(bookId)).data.fileName == fileName;

      allow delete: if false;
    }

    /* =========================
       👤 USER ASSETS (AVATAR / BANNER / POSTS)
       ========================= */
    match /users/{uid}/{category}/{allPaths=**} {
      allow read: if category in ['avatar', 'banner', 'cover', 'post', 'venue', 'misc'];

      allow write: if isOwner(uid)
        && category in ['avatar', 'banner', 'cover', 'post', 'venue', 'misc']
        && isImage()
        && (
          (category == 'avatar' && request.resource.size < 5 * 1024 * 1024)
          || (category != 'avatar' && request.resource.size < 10 * 1024 * 1024)
        );
    }

    /* =========================
       ✍️ WRITE PROJECT EXPORTS
       ========================= */
    match /projects/{uid}/{projectId}/exports/{fileName} {
      allow read: if isOwner(uid);

      allow write: if isOwner(uid)
        && request.resource.size > 0
        && request.resource.size <= 50 * 1024 * 1024
        && (isPdf() || isEpub());

      allow delete: if false;
    }

    /* =========================
       📎 ATTACHMENTS (EBOOK FILES)
       ========================= */
    /*
      ATTACHMENT_SECURITY_V1
      - No public reads ever
      - Access is ALWAYS mediated (signed URLs / reader service)
      - Uploads only by owner
    */
    match /attachments/{ownerUid}/{attachmentId} {

      // ❌ No direct reads
      allow read: if false;

      // ❌ No direct client writes; uploads must use server-issued signed URLs.
      allow write: if false;

      // ❌ No deletes from client
      allow delete: if false;
    }

    /* =========================
       DATA IMPORTS (PRIVATE)
       ========================= */
    match /imports/{uid}/{allPaths=**} {
      allow read, write: if isOwner(uid);
    }

    /* =========================
       FEEDBACK ATTACHMENTS
       ========================= */
    match /feedback/{uid}/{allPaths=**} {
      allow create: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024;

      allow read: if false;
    }

    /* =========================
       VENUE IMAGES (PUBLIC)
       ========================= */
    match /venues/{ownerUid}/{allPaths=**} {
      allow read: if true;

      allow write: if isOwner(ownerUid)
        && isImage()
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
