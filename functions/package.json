{
  "name": "booktown-functions",
  "main": "lib/index.js",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "contract:sync": "node scripts/syncContracts.cjs",
    "contract:parity": "npm run contract:sync && ts-node src/contracts/parity/checkSurfaceParity.ts",
    "build": "npm run contract:sync && tsc",
    "review:release-gate": "node scripts/reviewStackReleaseGate.cjs",
    "backfill:user-reviews-projection": "node scripts/backfillUserReviewsProjection.cjs",
    "seed:intelligence-personas": "node scripts/seedIntelligencePersonas.cjs",
    "populate:account": "node scripts/populateAccount.cjs",
    "backfill:authors:dry": "node scripts/backfillAuthorMetadata.cjs --dry-run=true",
    "backfill:authors:write": "node scripts/backfillAuthorMetadata.cjs --dry-run=false",
    "backfill:seed-authors:dry": "node scripts/backfillSeedAuthorSourceMetadata.cjs --dry-run=true",
    "backfill:seed-authors:write": "node scripts/backfillSeedAuthorSourceMetadata.cjs --dry-run=false",
    "backfill:reading-progress:dry": "node scripts/backfillReadingProgressCanonical.cjs --dry-run=true",
    "backfill:reading-progress:write": "node scripts/backfillReadingProgressCanonical.cjs --dry-run=false",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "jszip": "^3.10.1",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.2",
    "@types/uuid": "^9.0.7",
    "firebase-functions-test": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
