{
  "name": "booktown-functions",
  "main": "lib/index.js",
  "private": true,

  "engines": {
    "node": "20"
  },

  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",

    "test": "vitest run",
    "test:watch": "vitest"
  },

  "dependencies": {
    "@google/genai": "latest",
    "express": "^4.19.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1"
  },

  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.2",
    "@types/uuid": "^9.0.7",

    "firebase-functions-test": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",

    "vitest": "^4.0.18"
  }
}