{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    "outDir": "lib",
    "rootDir": "src",

    "sourceMap": true,

    "strict": true,
    "noImplicitReturns": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "skipLibCheck": true,
    "esModuleInterop": true,

    "moduleResolution": "node",
    "types": ["node"]
  },

  "compileOnSave": true,

  "include": ["src"],

  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**"
  ]
}